# Copia a `.env` y ajusta. Para desarrollo sin Redis local: LOGIN_REQUIRE_REDIS=0.
APP_SECRET_KEY=replace_with_fernet_key
SERVICE_JWT_SECRET=replace_with_dedicated_service_jwt_secret
# PostgreSQL (produccion) — SQLite se usa como fallback si no se define DATABASE_URL
DATABASE_URL=postgresql://superagente:replace_with_strong_postgres_password@localhost:5432/superagente
# DATABASE_URL=sqlite:///data/superagente.db  # Desarrollo local sin PostgreSQL
POSTGRES_PASSWORD=replace_with_strong_postgres_password
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace_with_strong_grafana_password
REDIS_PASSWORD=replace_with_strong_redis_password
REDIS_URL=redis://:replace_with_strong_redis_password@redis:6379/0
# Solo en redes con inspección TLS/proxy que sustituyen certificados de PyPI.
# Preferible: instalar la CA corporativa en Docker Desktop y dejar esto vacío.
# PIP_TRUSTED_HOSTS=pypi.org files.pythonhosted.org
ENVIRONMENT=production
# TLS (docker compose -f docker-compose.yml -f docker-compose.ssl.yml)
# NGINX_SSL_CONFIG=./deploy/nginx.ssl.conf
# NGINX_SSL_DOMAIN=tu-dominio.com
# LETSENCRYPT_EMAIL=admin@tu-dominio.com
# Backups: scripts/backup_postgres.sh — BACKUP_DIR, BACKUP_RETENTION_DAYS
UPLOAD_POLICY=strict
MAX_IMAGE_MB=15
MAX_VIDEO_MB=100
MAX_AUDIO_MB=100
MAX_DOC_MB=25
RATE_LIMIT_CHAT_LIMIT=10
RATE_LIMIT_CHAT_WINDOW=60
RATE_LIMIT_UPLOADS_LIMIT=20
RATE_LIMIT_UPLOADS_WINDOW=300
RATE_LIMIT_TOOLS_LIMIT=30
RATE_LIMIT_TOOLS_WINDOW=300
RATE_LIMIT_LOGIN_LIMIT=8
RATE_LIMIT_LOGIN_WINDOW=300
RATE_LIMIT_LOGIN_IP_LIMIT=8
RATE_LIMIT_LOGIN_IP_WINDOW=300
RATE_LIMIT_LOGIN_USER_LIMIT=8
RATE_LIMIT_LOGIN_USER_WINDOW=300
LOGIN_BACKOFF_IP_BASE_SECONDS=2
LOGIN_BACKOFF_IP_MAX_SECONDS=60
LOGIN_BACKOFF_IP_TRIGGER_FAILURES=3
LOGIN_BACKOFF_USER_BASE_SECONDS=2
LOGIN_BACKOFF_USER_MAX_SECONDS=60
LOGIN_BACKOFF_USER_TRIGGER_FAILURES=3
# Producción con Redis: 1 (preferir Redis para límites de login). Desarrollo local sin Redis: 0.
LOGIN_REQUIRE_REDIS=0
# Si quedaste bloqueado por intentos de login: pon 1, recarga la página una vez, vuelve a 0 y reinicia Streamlit.
CLEAR_LOGIN_RATELIMIT=0
REMEMBER_ME_DAYS=7
SESSION_IDLE_TIMEOUT_MINUTES=120
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.15
# OpenTelemetry OTLP (gRPC). Vacío = sin trazas. Por defecto se usa TLS al colector;
# solo en entornos sin TLS (p. ej. Jaeger local): OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_INSECURE=false
ENABLE_ASYNC_TASKS=1
RQ_QUEUE_NAME=superagente
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_MODEL_FALLBACKS=gemini-2.5-flash,gemini-2.0-flash
GEMINI_MAX_TOKENS=8192
GEMINI_TEMPERATURE=0.2
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile
# Opcional: otro modelo si falla el principal (no usar 8b-instant con adjuntos grandes)
# GROQ_EXTRA_FALLBACK_MODEL=
GROQ_MAX_USER_CHARS=28000
GROQ_INLINE_ATTACHMENT_MAX_CHARS=28000
GROQ_MAX_TOKENS=8192
GROQ_TEMPERATURE=0.2
GROQ_CONTINUATION_ROUNDS=2
OPENROUTER_API_KEY=
OPENROUTER_MAX_TOKENS=8192
OPENROUTER_TEMPERATURE=0.2
OPENROUTER_CONTINUATION_ROUNDS=2
CUSTOM_OPENAI_MAX_TOKENS=8192
CUSTOM_OPENAI_TEMPERATURE=0.2
OLLAMA_MAX_TOKENS=8192
OLLAMA_TEMPERATURE=0.2
OPENAI_API_KEY=
STABILITY_API_KEY=
CLAMSCAN_BIN=
# SMTP — Brevo (brevo.com) plan gratuito: 300 emails/día.
SMTP_SERVER=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=SuperAgente IA Pro <superagenteiapro@gmail.com>
