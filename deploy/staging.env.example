# ============================================================================
# STAGING ENVIRONMENT CONFIGURATION
# Copy to .env and fill in ALL values before deploying.
# ============================================================================

# --- Core Security (REQUIRED - generate unique values!) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_SECRET_KEY=CHANGE_ME_GENERATE_A_REAL_FERNET_KEY

# --- Database ---
DATABASE_URL=postgresql://superagente:${POSTGRES_PASSWORD}@postgres:5432/superagente
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Environment ---
ENVIRONMENT=staging
UPLOAD_POLICY=strict

# --- Rate Limiting ---
RATE_LIMIT_CHAT_LIMIT=15
RATE_LIMIT_CHAT_WINDOW=60
RATE_LIMIT_UPLOADS_LIMIT=20
RATE_LIMIT_UPLOADS_WINDOW=300
RATE_LIMIT_TOOLS_LIMIT=30
RATE_LIMIT_TOOLS_WINDOW=300
RATE_LIMIT_LOGIN_LIMIT=8
RATE_LIMIT_LOGIN_WINDOW=300
RATE_LIMIT_LOGIN_IP_LIMIT=8
RATE_LIMIT_LOGIN_IP_WINDOW=300
RATE_LIMIT_LOGIN_USER_LIMIT=8
RATE_LIMIT_LOGIN_USER_WINDOW=300
LOGIN_BACKOFF_IP_BASE_SECONDS=2
LOGIN_BACKOFF_IP_MAX_SECONDS=60
LOGIN_BACKOFF_IP_TRIGGER_FAILURES=3
LOGIN_BACKOFF_USER_BASE_SECONDS=2
LOGIN_BACKOFF_USER_MAX_SECONDS=60
LOGIN_BACKOFF_USER_TRIGGER_FAILURES=3
LOGIN_REQUIRE_REDIS=1
REMEMBER_ME_DAYS=7
SESSION_IDLE_TIMEOUT_MINUTES=120

# --- File Limits ---
MAX_IMAGE_MB=15
MAX_VIDEO_MB=100
MAX_AUDIO_MB=100
MAX_DOC_MB=25

# --- Observability ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.25
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# --- LLM Providers (fill at least one) ---
GEMINI_API_KEY=
GEMINI_MAX_TOKENS=8192
GEMINI_TEMPERATURE=0.2
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=8192
GROQ_TEMPERATURE=0.2
OPENROUTER_API_KEY=
OPENROUTER_MAX_TOKENS=8192
OPENROUTER_TEMPERATURE=0.2
OPENAI_API_KEY=
STABILITY_API_KEY=

# --- Email (SMTP) ---
SMTP_SERVER=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=SuperAgente IA Pro <noreply@yourdomain.com>
ADMIN_NOTIFICATION_EMAIL=

# --- Async Tasks ---
ENABLE_ASYNC_TASKS=1
RQ_QUEUE_NAME=superagente
